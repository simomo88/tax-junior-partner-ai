# ============================================================================
# Tax Junior Partner AI - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your configuration values
# Never commit .env file - it contains secrets!

# ============================================================================
# Application Configuration
# ============================================================================
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ============================================================================
# LLM Configuration (OpenAI)
# ============================================================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Alternative: Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# ============================================================================
# Embeddings Configuration
# ============================================================================
# Option 1: OpenAI Embeddings
EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Option 2: HuggingFace (local)
# EMBEDDINGS_PROVIDER=huggingface
# HUGGINGFACE_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================================================
# Vector Database Configuration
# ============================================================================
# Chroma (local, default)
VECTOR_DB_TYPE=chroma
VECTOR_DB_PATH=./data/vector_store

# Alternative: Weaviate (remote)
# VECTOR_DB_TYPE=weaviate
# WEAVIATE_URL=http://localhost:8080

# ============================================================================
# News Scraper Configuration
# ============================================================================
SCRAPER_AGENZIA_ENTRATE_URL=https://www.agenziaentrate.gov.it
SCRAPER_TIMEOUT=30
SCRAPER_RETRIES=3
SCRAPER_RATE_LIMIT=1  # Requests per second

# ============================================================================
# Database Configuration
# ============================================================================
KB_DATA_PATH=./data/knowledge_base
KB_BACKUP_PATH=./data/backups

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_PATH=./logs
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_NEWS_SCRAPER=true
FEATURE_SEMANTIC_SEARCH=true
FEATURE_RISK_ANALYZER=true
FEATURE_DAILY_BRIEFING=true

# ============================================================================
# Performance Configuration
# ============================================================================
MAX_SEARCH_RESULTS=10
EMBEDDING_BATCH_SIZE=32
LLM_REQUEST_TIMEOUT=60
VECTOR_STORE_BATCH_SIZE=100
